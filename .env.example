# VideoSDK Credentials (Required)
# Get your API Key from: https://app.videosdk.live/api-keys
VIDEOSDK_API_KEY=your_videosdk_api_key
VIDEOSDK_SECRET_KEY=your_videosdk_secret_key

# Provider Credentials
SARVAMAI_API_KEY=your_sarvamai_api_key
GOOGLE_API_KEY=your_google_ai_api_key
CARTESIA_API_KEY=your_cartesia_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
OPENAI_API_KEY=your_openai_api_key

# Optional: Default Room ID for testing (Used by agent)
VIDEOSDK_ROOM_ID=your_videosdk_room_id

# Generated Token (Optional, can be generated by backend)
VIDEOSDK_AUTH_TOKEN=your_videosdk_auth_token

# Google Calendar Integration
GOOGLE_OAUTH_CLIENT_SECRET_JSON=path/to/your/client_secret.json
GOOGLE_CALENDAR_ID=your_email@gmail.com
CALENDAR_TIMEZONE=Asia/Kolkata

# Zapier MCP
ZAPIER_MCP_API_KEY=your_zapier_mcp_api_key
